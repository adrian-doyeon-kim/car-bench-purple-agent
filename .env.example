# Required: API key for your chosen model provider
# OpenAI (default: openai/gpt-5-mini)
OPENAI_API_KEY=

# If using Anthropic models
# ANTHROPIC_API_KEY=

# If using Gemini (and for the green evaluator's simulated user)
# GEMINI_API_KEY=

# Optional model overrides (defaults shown below)
# AGENT_LLM=openai/gpt-5-mini
# AGENT_THINKING=true
# AGENT_REASONING_EFFORT=medium
# AGENT_TEMPERATURE=1.0
# AGENT_INTERLEAVED_THINKING=true
# AGENT_TIMEOUT=120

# Deep trace logging (disabled if unset)
# AGENT_TRACE_DIR=./logs/traces

# LOGURU_LEVEL=INFO
